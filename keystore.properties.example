# Release signing config — copy to `keystore.properties` (git-ignored) and fill in.
# Paths are resolved relative to the module root (this directory).
#
# Create an upload keystore once with:
#   keytool -genkeypair -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 \
#     -validity 10000 -alias upload
# then enroll in Play App Signing (Play Console handles the app signing key).

storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
